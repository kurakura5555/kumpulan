                      ],
                      "skillvideo": ""
                    },
                    {
                      "skillcd&cost": "CD: 12",
                      "skilldesc": "Yin berlari ke depan, meninggalkan <font color=\"a6aafb\">Golden Ring</font> di belakang dan memberikan 75<font color=\"fba51f\"> (+35% Extra Physical Attack)</font> <font color=\"fb1f1f\">Physical Damage</font> ke lawan di jalurnya. Dia memperoleh 30% Pengurangan Damage tambahan selama 4 detik jika mengenai Hero lawan.\nSetelah 1 detik, <font color=\"a6aafb\">Golden Ring</font> akan menyusul Yin, memberikan 150<font color=\"fba51f\"> (+70% Extra Physical Attack)</font> <font color=\"fb1f1f\">Physical Damage</font> ke lawan yang dilewatinya dan menyebabkan Stun selama 1 detik.\n",
                      "skillicon": "https://akmweb.youngjoygame.com/web/svnres/img/mlbb/homepage/100_9840f60d6b05aa1cb9513397d574df12.png",
